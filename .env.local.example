# Terminia Frontend — Environment Variables
# Copy to .env.local:  cp .env.local.example .env.local

# Supabase (public — embedded in client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://supabase-terminia.pezserv.org
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# NemoClaw API (server-side only — used by Next.js rewrites)
# In Docker: http://terminia-api:3100 (internal DNS)
# In dev:    https://nemoclaw.pezserv.org (public)
NEMOCLAW_API_URL=https://nemoclaw.pezserv.org
